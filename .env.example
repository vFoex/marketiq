# Environment Variables for Development

# ANTHROPIC_API_KEY= # dev only — Bedrock uses IAM in deploy
POSTGRES_USER=marketiq
POSTGRES_PASSWORD=password
POSTGRES_DB=marketiq
# Host port 5433 — compose maps 5433:5432 (avoids clashing with a local Postgres on 5432)
DATABASE_URL=postgresql+psycopg://marketiq:password@localhost:5433/marketiq
SYMBOLS=["BTCUSDT"]
# Combined-stream base (no /ws) — the client appends /stream?streams=...
# Public market-data host on :443 (firewall-friendly; stream.binance.com:9443 is
# often blocked). wss://stream.binance.com:443 also works.
BINANCE_WS_URL=wss://data-stream.binance.vision
BINANCE_REST_URL=https://api.binance.com/api/v3
METRICS_WINDOW_SECONDS=60
METRICS_INTERVAL_SECONDS=5
API_HOST=0.0.0.0
API_PORT=8000
